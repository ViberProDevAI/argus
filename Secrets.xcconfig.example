// Secrets.xcconfig.example
// ----------------------------------------------------------------------------
// Bu dosyayı `Secrets.xcconfig` olarak kopyala, kendi anahtarlarınla doldur.
// Secrets.xcconfig gitignore'da — kişisel anahtarların commit'e sızmaz.
//
// Her satır "ANAHTAR = DEĞER" biçimindedir. Boş bıraktığın key'ler için ilgili
// servis graceful degrade eder (Argus çalışmaya devam eder, sadece o servis
// devre dışı görünür). Hangi key'in hangi özelliği açtığı yorum satırlarında.
// ----------------------------------------------------------------------------

// === Market Data Providers ==================================================
// Fiyat + mum + fundamental fan-out. En az 3-4 tanesi dolu olmalı ki Orion
// MTF analizi veri boşluğunu tolere edebilsin.
TWELVE_DATA_KEY = YOUR_TWELVE_DATA_KEY
FMP_KEY = YOUR_FMP_KEY
FINNHUB_KEY = YOUR_FINNHUB_KEY
TIINGO_KEY = YOUR_TIINGO_KEY
MARKETSTACK_KEY = YOUR_MARKETSTACK_KEY
ALPHA_VANTAGE_KEY = YOUR_ALPHA_VANTAGE_KEY
EODHD_KEY = YOUR_EODHD_KEY
FRED_KEY = YOUR_FRED_KEY

// === LLM / AI Providers =====================================================
// Orion conviction açıklaması, ChartPatternEngine (Gemini vision), Alkindus
// embedding (Gemini). GEMINI_KEY zorunlu; diğerleri optional fallback.
GROQ_KEY = YOUR_GROQ_KEY
GEMINI_KEY = YOUR_GEMINI_KEY
GEMINI_KEY_BACKUP =
DEEPSEEK_KEY = YOUR_DEEPSEEK_KEY
GLM_KEY = YOUR_GLM_KEY

// === RAG / Pinecone =========================================================
// Opsiyonel. PINECONE_KEY + PINECONE_BASE_URL ikisi birden dolu değilse
// Alkindus RAG öğrenme (`syncTrade`, `searchPatterns` vb.) sessizce atlanır;
// uygulamanın geri kalanı normal çalışır.
//
// BASE_URL örneği: https://<index>-<project>.svc.<region>.pinecone.io
// Bu URL'i Pinecone konsolunda index'i oluşturduğunda "Connect" ekranında
// görürsün. Her abonenin kendi hesabı → kendi URL'i olacak.
PINECONE_KEY = YOUR_PINECONE_KEY
PINECONE_BASE_URL =

// === Turkish Market (BIST) ==================================================
// BorsaPy self-hosted Render endpoint. BORSAPY_URL boşsa Argus otomatik
// olarak Yahoo/Finnhub fallback'ine düşer — ama BIST fundamental verisi o
// sağlayıcılarda kısıtlı, önermiyoruz. Kendi Render deploy'unu yapmak 10 dk.
BORSAPY_KEY =
BORSAPY_URL =

// === Turkish FX (doviz.com) =================================================
// USD/TRY, EUR/TRY spot. Opsiyonel.
DOVIZCOM_KEY =
